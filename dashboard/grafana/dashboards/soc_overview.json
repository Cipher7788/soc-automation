  ],
  "annotations": {"list": []},
  "description": "SOC Automation — Security Operations Center Overview Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [
        {
          "datasource": "Wazuh-OpenSearch",
          "query": "",
          "metrics": [{"type": "count", "id": "1"}],
          "timeField": "timestamp",
          "bucketAggs": []
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
    },
    {
      "id": 2,
      "title": "Critical Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": "Wazuh-OpenSearch",
          "query": "rule.level:>=12",
          "metrics": [{"type": "count", "id": "1"}],
          "timeField": "timestamp",
          "bucketAggs": []
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 3,
      "title": "High Severity Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": "Wazuh-OpenSearch",
          "query": "rule.level:[8 TO 11]",
          "metrics": [{"type": "count", "id": "1"}],
          "timeField": "timestamp",
          "bucketAggs": []
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "orange"}}}
    },
    {
      "id": 4,
      "title": "Active Agents",
      "type": "stat",
