      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": "Wazuh-OpenSearch",
          "query": "",
          "metrics": [{"type": "cardinality", "id": "1", "field": "agent.id"}],
          "timeField": "timestamp",
          "bucketAggs": []
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 5,
