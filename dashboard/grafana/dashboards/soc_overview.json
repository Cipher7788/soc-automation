        {
          "datasource": "Wazuh-OpenSearch",
          "query": "",
          "metrics": [{"type": "count", "id": "1"}],
          "timeField": "timestamp",
          "bucketAggs": [
            {"type": "date_histogram", "id": "2", "field": "timestamp", "settings": {"interval": "auto", "min_doc_count": "0"}}
          ]
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
