          "datasource": "Wazuh-OpenSearch",
          "query": "",
          "metrics": [{"type": "count", "id": "1"}],
          "timeField": "timestamp",
          "bucketAggs": [
            {"type": "terms", "id": "2", "field": "rule.level", "settings": {"size": "10", "order": "desc", "orderBy": "_count"}}
