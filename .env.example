# ─── Wazuh ────────────────────────────────────────────────────────────────────
WAZUH_HOST=https://wazuh-manager:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=changeme
WAZUH_VERIFY_SSL=false
WAZUH_POLL_INTERVAL=60

# ─── TheHive ──────────────────────────────────────────────────────────────────
THEHIVE_URL=http://thehive:9000
THEHIVE_API_KEY=your-thehive-api-key

# ─── Shuffle ──────────────────────────────────────────────────────────────────
SHUFFLE_URL=http://shuffle-backend:3001
SHUFFLE_API_KEY=your-shuffle-api-key

# ─── Threat Intelligence ──────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
OTX_API_KEY=your-otx-api-key

# ─── Notifications ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=soc@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=soc@example.com
SMTP_TO=alerts@example.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

WEBHOOK_URL=https://your-webhook-endpoint.example.com/alert

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
ALERT_DEDUP_WINDOW=300
CACHE_TTL=3600
ML_MODEL_PATH=models/isolation_forest.pkl
RULES_DIR=rules
PLAYBOOKS_DIR=playbooks
